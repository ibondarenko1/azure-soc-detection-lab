{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "comments": "Phase K SOAR+AI playbook for DET-004 (Mass resource deletion). On the incident, a managed-identity Logic App invokes a Microsoft Security Copilot promptbook ('DET-004 Mass Deletion Triage') and posts the AI investigation summary back as an incident comment. No stored secret. REQUIRES provisioned Security Copilot capacity (>= 1 SCU) for the Copilot action to succeed, see ../../docs/06-security-copilot.md for the cost-bounded run/teardown runbook. Two connector-specific bindings are finalized in the Logic App designer and noted inline: (1) the Security Copilot action operation path, (2) the output field read into the comment.",
    "designerBindings": {
      "copilotActionOperation": "Security Copilot connector -> 'Submit a Security Copilot promptbook'. Confirm the exact operation path/operationId for your tenant in the designer; the connection ref below is the durable part.",
      "copilotOutputField": "The promptbook evaluation output field read into the comment (body(...)?['summary']) is connector-version dependent; bind the actual 'Evaluation result/summary' output in the designer."
    }
  },
  "parameters": {
    "playbookName": { "type": "string", "defaultValue": "pb-copilot-triage" },
    "location": { "type": "string", "defaultValue": "[resourceGroup().location]" },
    "promptbookName": { "type": "string", "defaultValue": "DET-004 Mass Deletion Triage" },
    "lookbackHours": { "type": "string", "defaultValue": "24" }
  },
  "variables": {
    "sentinelConnName": "azuresentinel-copilot-mi",
    "sentinelConnId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/azuresentinel')]",
    "copilotConnName": "securitycopilot-copilot",
    "copilotConnId": "[concat('/subscriptions/', subscription().subscriptionId, '/providers/Microsoft.Web/locations/', parameters('location'), '/managedApis/securitycopilot')]"
  },
  "resources": [
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('sentinelConnName')]",
      "location": "[parameters('location')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('sentinelConnName')]",
        "customParameterValues": {},
        "parameterValueType": "Alternative",
        "api": { "id": "[variables('sentinelConnId')]" }
      }
    },
    {
      "type": "Microsoft.Web/connections",
      "apiVersion": "2016-06-01",
      "name": "[variables('copilotConnName')]",
      "location": "[parameters('location')]",
      "kind": "V1",
      "properties": {
        "displayName": "[variables('copilotConnName')]",
        "customParameterValues": {},
        "api": { "id": "[variables('copilotConnId')]" }
      }
    },
    {
      "type": "Microsoft.Logic/workflows",
      "apiVersion": "2019-05-01",
      "name": "[parameters('playbookName')]",
      "location": "[parameters('location')]",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.Web/connections', variables('sentinelConnName'))]",
        "[resourceId('Microsoft.Web/connections', variables('copilotConnName'))]"
      ],
      "properties": {
        "state": "Enabled",
        "definition": {
          "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
          "contentVersion": "1.0.0.0",
          "parameters": {
            "$connections": { "type": "Object", "defaultValue": {} },
            "promptbookName": { "type": "String", "defaultValue": "[parameters('promptbookName')]" },
            "lookbackHours": { "type": "String", "defaultValue": "[parameters('lookbackHours')]" }
          },
          "triggers": {
            "Microsoft_Sentinel_incident": {
              "type": "ApiConnectionWebhook",
              "inputs": {
                "body": { "callback_url": "@{listCallbackUrl()}" },
                "host": { "connection": { "name": "@parameters('$connections')['azuresentinel']['connectionId']" } },
                "path": "/incident-creation"
              }
            }
          },
          "actions": {
            "Run_Security_Copilot_promptbook": {
              "type": "ApiConnection",
              "inputs": {
                "host": { "connection": { "name": "@parameters('$connections')['securitycopilot']['connectionId']" } },
                "method": "post",
                "path": "/promptbooks/evaluations",
                "body": {
                  "promptbookName": "@parameters('promptbookName')",
                  "promptbookInputs": {
                    "IncidentArmId": "@{triggerBody()?['object']?['id']}",
                    "LookbackHours": "@parameters('lookbackHours')"
                  }
                }
              },
              "runAfter": {}
            },
            "Post_Copilot_summary_as_comment": {
              "type": "Http",
              "runAfter": { "Run_Security_Copilot_promptbook": [ "Succeeded" ] },
              "inputs": {
                "method": "PUT",
                "uri": "https://management.azure.com@{triggerBody()?['object']?['id']}/comments/@{guid()}?api-version=2023-11-01",
                "body": {
                  "properties": {
                    "message": "@{concat('**Security Copilot, DET-004 AI triage**\n\n', coalesce(body('Run_Security_Copilot_promptbook')?['summary'], 'Security Copilot returned no summary; open the promptbook evaluation for full output.'))}"
                  }
                },
                "authentication": { "type": "ManagedServiceIdentity", "audience": "https://management.azure.com" }
              }
            }
          },
          "outputs": {}
        },
        "parameters": {
          "$connections": {
            "value": {
              "azuresentinel": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('sentinelConnName'))]",
                "connectionName": "[variables('sentinelConnName')]",
                "id": "[variables('sentinelConnId')]",
                "connectionProperties": { "authentication": { "type": "ManagedServiceIdentity" } }
              },
              "securitycopilot": {
                "connectionId": "[resourceId('Microsoft.Web/connections', variables('copilotConnName'))]",
                "connectionName": "[variables('copilotConnName')]",
                "id": "[variables('copilotConnId')]"
              }
            }
          }
        }
      }
    }
  ],
  "outputs": {
    "playbookResourceId": { "type": "string", "value": "[resourceId('Microsoft.Logic/workflows', parameters('playbookName'))]" },
    "playbookPrincipalId": { "type": "string", "value": "[reference(resourceId('Microsoft.Logic/workflows', parameters('playbookName')), '2019-05-01', 'Full').identity.principalId]" }
  }
}
